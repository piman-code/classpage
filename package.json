{
  "name": "classpage",
  "version": "0.4.1",
  "description": "A read-first Obsidian classroom dashboard for student forms and teacher summaries.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "telegram:chat-id": "node scripts/get-telegram-chat-id.mjs",
    "telegram:send": "node scripts/send-telegram-message.mjs",
    "telegram:wrap": "node scripts/run-task-with-telegram.mjs",
    "telegram:bridge": "node scripts/telegram-codex-bridge.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.1",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2"
  }
}
